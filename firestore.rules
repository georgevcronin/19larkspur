rules_version = '2';
service cloud.firestore {
  // True typo-tolerant (edit-distance) fuzzy matching isn't possible here —
  // Firestore Rules has no loops/recursion, so there's no way to compute a
  // Levenshtein distance or similar. Instead this does a partial/reordered
  // match: as long as the housemate's first name and surname both appear
  // somewhere in the signed-in Google account's display name, it counts.
  // That tolerates a differently-ordered name, a middle name or initial,
  // and extra whitespace or capitalisation — but not misspellings.
  function normalizedName() {
    return request.auth.token.name.lower().trim();
  }
  function hasBoth(name, first, last) {
    return name.matches('.*' + first + '.*') && name.matches('.*' + last + '.*');
  }
  function isHousemate(name) {
    return hasBoth(name, 'george', 'cronin') ||
           hasBoth(name, 'george', 'bale') ||
           hasBoth(name, 'alexander', 'pear') ||
           hasBoth(name, 'freddie', 'smith') ||
           hasBoth(name, 'oliver', 'shawyer');
  }

  match /databases/{database}/documents {
    match /favours/{entry} {
      // Keep the first-name/surname pairs above in sync with the
      // HOUSEMATES names in committees.js.
      allow read, write: if request.auth != null && isHousemate(normalizedName());
    }
  }
}
